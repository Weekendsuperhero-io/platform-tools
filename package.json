{
	"name": "repo-structure-and-rules",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.29.3",
	"engines": {
		"node": ">=18",
		"pnpm": "10.x"
	},
	"scripts": {
		"preinstall": "node scripts/enforce-pnpm.cjs",
		"build": "node scripts/enforce-pnpm.cjs && tsc -p tsconfig.json",
		"check": "node scripts/enforce-pnpm.cjs && tsc -p tsconfig.json --noEmit",
		"apply:baseline": "node scripts/enforce-pnpm.cjs && node dist/apply-github-baseline.js",
		"apply:low-cost": "node scripts/enforce-pnpm.cjs && node dist/apply-github-baseline.js --config config/security-low-cost.json",
		"apply": "node scripts/enforce-pnpm.cjs && node dist/apply-github-baseline.js --config config/security-low-cost.json"
	},
	"dependencies": {
		"octokit": "^5.0.5"
	},
	"devDependencies": {
		"@types/node": "^24.12.0",
		"typescript": "^5.9.3"
	}
}
